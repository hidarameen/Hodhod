modules = ["nodejs-20", "python-3.11", "web", "bash", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full", "freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "postgresql", "tcl", "tk", "zlib"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "5000"
PYTHONUNBUFFERED = "1"
